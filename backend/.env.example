# ── Google Cloud Config ────────────────────────────────────────────────────────
GOOGLE_CLOUD_PROJECT=
PROJECT_ID=

VERTEX_LOCATION=us-central1
VERTEX_MODEL=gemini-2.5-flash

# BigQuery Table
DATASET_NAME=decisioniq
TABLE_NAME=inventory_data

# Optional path to local credentials (unneeded on Cloud Run where ADC is automatic)
GOOGLE_APPLICATION_CREDENTIALS=

# ── App Config ─────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins (e.g. https://your-app.web.app)
ALLOWED_ORIGINS=

# Set to true to allow wildcard * CORS (strictly for dev mode)
ALLOW_ALL_ORIGINS=false

# Options: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
